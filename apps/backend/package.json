{
  "name": "@vue-bun-explorer/backend",
  "version": "1.0.0",
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun build src/index.ts --outdir dist",
    "lint": "eslint src",
    "test": "bun test",
    "prisma:generate": "bunx prisma generate",
    "prisma:migrate": "bunx prisma db push",
    "prisma:studio": "bunx prisma studio",
    "prisma:seed": "bunx prisma generate && bun run prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@vue-bun-explorer/shared-types": "workspace:*",
    "elysia": "^1.0.0",
    "elysia-rate-limit": "^4.6.2"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^20.0.0",
    "prisma": "^5.22.0",
    "typescript": "^5.0.0"
  }
}
